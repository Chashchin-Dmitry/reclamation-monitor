# Database (if needed)
ROOT_DB_PASSWORD=your_db_password_here

# Email credentials (Yandex)
EMAIL_USER=your_email@yandex.ru
EMAIL_HOST=imap.yandex.ru
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
IMAP_PASSWORD=your_app_password_here
SMTP_PASSWORD=your_app_password_here

# LLM API (Ollama Native API)
# ВАЖНО: используется Native API (/api/chat), НЕ OpenAI-compatible (/v1/...)
LLAMA_API_URL=http://localhost:11434/api/chat
LLAMA_MODEL=qwen3:30b-a3b

# Operation mode: monitor / email / demo
TEST_MODE=monitor
MONITOR_INTERVAL=2
USE_CURRENT_DATE=true
#TEST_DATE=10-Apr-2025

# Email forwarding recipients
DEFAULT_RECIPIENT=your_email@gmail.com
COPY_RECIPIENT=your_backup@yandex.ru

# Outgoing filter: comma-separated domains to skip (auto-derived from EMAIL_USER if not set)
# OUR_EMAIL_DOMAINS=@your-company.ru,@your-company-group.ru

# Senders from company domain whose emails still go through LLaMA analysis (comma-separated)
# ALLOWED_SENDERS=trusted.employee@your-company.ru

# Bitrix24 webhook URL
BITRIX24_WEBHOOK=https://your_company.bitrix24.ru/rest/USER_ID/WEBHOOK_CODE/
